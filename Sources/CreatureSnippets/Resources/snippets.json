    "function": "function ${Name} (${args}) return ${Type} is\nbegin\n   ${body}\nend ${Name};",
    "for": "for ${I} in ${range} loop\n   ${body}\nend loop;",
    "if": "if ${cond} then\n   ${body}\nend if;",
    "with": "with ${Package};",
    "print": "Put_Line (${value});"
  },
  "groovy": {
    "function": "def ${name}(${args}) {\n    ${body}\n}",
