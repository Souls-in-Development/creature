    "for": "${collection}.each do |${item}|\n  ${body}\nend",
    "if": "if ${cond}\n  ${body}\nend",
    "require": "require \"${lib}\"",
    "print": "puts ${value}"
  },
  "d": {
    "function": "${ret} ${name}(${args}) {\n    ${body}\n}",
    "struct": "struct ${Name} {\n    ${body}\n}",
    "class": "class ${Name} {\n    ${body}\n}",
    "foreach": "foreach (${item}; ${range}) {\n    ${body}\n}",
    "if": "if (${cond}) {\n    ${body}\n}",
    "import": "import ${module};",
    "print": "writeln(${value});"
  },
  "fortran": {
