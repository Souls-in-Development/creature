    "if": "if (${cond}) {\n    ${body}\n}",
    "each": "${collection}.each { ${item} ->\n    ${body}\n}",
    "import": "import ${package}",
    "print": "println ${value}"
  },
  "powershell": {
    "function": "function ${Name} {\n    param(${args})\n    ${body}\n}",
    "for": "foreach (${item} in ${collection}) {\n    ${body}\n}",
    "if": "if (${cond}) {\n    ${body}\n}",
    "while": "while (${cond}) {\n    ${body}\n}",
    "try": "try {\n    ${body}\n} catch {\n    ${handler}\n}",
    "print": "Write-Output ${value}"
  },
  "vbnet": {
    "function": "Function ${Name}(${args}) As ${Type}\n    ${body}\nEnd Function",
    "sub": "Sub ${Name}(${args})\n    ${body}\nEnd Sub",
    "class": "Public Class ${Name}\n    ${body}\nEnd Class",
    "for": "For ${i} As Integer = 0 To ${n}\n    ${body}\nNext",
    "if": "If ${cond} Then\n    ${body}\nEnd If",
    "imports": "Imports ${Namespace}",
    "print": "Console.WriteLine(${value})"
  },
  "matlab": {
    "function": "function ${ret} = ${name}(${args})\n    ${body}\nend",
    "for": "for ${i} = 1:${n}\n    ${body}\nend",
    "if": "if ${cond}\n    ${body}\nend",
    "while": "while ${cond}\n    ${body}\nend",
    "switch": "switch ${var}\n    case ${value}\n        ${body}\nend",
    "print": "disp(${value})"
  },
  "solidity": {
    "function": "function ${name}(${args}) ${visibility} returns (${ret}) {\n    ${body}\n}",
    "contract": "contract ${Name} {\n    ${body}\n}",
    "struct": "struct ${Name} {\n    ${type} ${field};\n}",
    "for": "for (uint ${i} = 0; ${i} < ${n}; ${i}++) {\n    ${body}\n}",
    "if": "if (${cond}) {\n    ${body}\n}",
    "mapping": "mapping(${key} => ${value}) public ${name};",
    "event": "event ${Name}(${args});"
  },
  "assembly": {
    "function": "${name}:\n    push rbp\n    mov rbp, rsp\n    ${body}\n    pop rbp\n    ret",
    "loop": "${label}:\n    ${body}\n    dec ${reg}\n    jnz ${label}",
    "if": "cmp ${a}, ${b}\n    jne ${label}\n    ${body}\n${label}:",
    "data": "${name}: db ${value}",
    "syscall": "mov rax, ${num}\n    syscall"
  }
}
