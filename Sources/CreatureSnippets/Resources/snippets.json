    "procedure": "procedure ${name}(${args});\nbegin\n  ${body}\nend;",
    "for": "for ${i} := 1 to ${n} do\nbegin\n  ${body}\nend;",
    "if": "if ${cond} then\nbegin\n  ${body}\nend;",
    "while": "while ${cond} do\nbegin\n  ${body}\nend;",
    "print": "writeln(${value});"
  },
  "ada": {
