    "subroutine": "subroutine ${name}(${args})\n    ${body}\nend subroutine ${name}",
    "do": "do ${i} = 1, ${n}\n    ${body}\nend do",
    "if": "if (${cond}) then\n    ${body}\nend if",
    "program": "program ${name}\n    ${body}\nend program ${name}",
    "print": "print *, ${value}"
  },
  "pascal": {
